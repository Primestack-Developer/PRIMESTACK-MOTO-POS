# Dependencies
node_modules/
admin-dashboard/node_modules/
merchant-dashboard/node_modules/
pos-app/node_modules/

# Environment variables — NEVER commit these
.env
.env.local
.env.development

# Keep production env files (they have no secrets)
!.env.production
!admin-dashboard/.env.production
!merchant-dashboard/.env.production
!pos-app/.env.production

# Database
prisma/dev.db
prisma/dev.db-journal
*.db
*.db-journal

# Logs
logs/
*.log
npm-debug.log*

# Build outputs (Railway builds them fresh)
admin-dashboard/dist/
merchant-dashboard/dist/
pos-app/dist/

# IDE
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln

# OS
.DS_Store
Thumbs.db
