generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  name         String
  pin          String?
  recoveryKey  String?  @unique
  lockedUntil  DateTime?
  failedLogins Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Merchant {
  id              String   @id @default(cuid())
  merchantId      String   @unique
  name            String
  email           String   @unique
  phone           String
  businessName    String
  address         String
  country         String
  password        String
  stripeAccountId String?
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  posDevices       POSDevice[]
  customers        Customer[]
  orders           Order[]
  transactions     Transaction[]
  verificationReqs CustomerVerification[]
  notifications    MerchantNotification[]
  chatMessages     ChatMessage[]
  disputes         Dispute[]
  fraudFlags       FraudFlag[]
  refunds          Refund[]
}

model POSDevice {
  id             String    @id @default(cuid())
  posId          String    @unique
  merchantId     String
  activationCode String    @unique
  status         String    @default("pending")
  deviceModel    String?
  deviceSerial   String?
  lastSeenAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  merchant     Merchant    @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  orders       Order[]
  deviceLogs   DeviceLog[]
  transactions Transaction[]
}

model Customer {
  id               String   @id @default(cuid())
  merchantId       String
  name             String
  email            String?
  phone            String?
  billingAddress   String?
  stripeCustomerId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  merchant     Merchant              @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  orders       Order[]
  verification CustomerVerification?
}

model CustomerVerification {
  id           String    @id @default(cuid())
  customerId   String    @unique
  merchantId   String
  status       String    @default("pending")
  documentUrls String    @default("[]")
  notes        String?
  reviewedBy   String?
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model MerchantNotification {
  id         String   @id @default(cuid())
  merchantId String
  type       String
  title      String
  message    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model AdminNotification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  data      String   @default("{}")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SystemStatus {
  id        String   @id @default(cuid())
  online    Boolean  @default(true)
  message   String   @default("System is operational")
  updatedBy String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model ChatMessage {
  id         String   @id @default(cuid())
  merchantId String
  sender     String   // 'admin' or 'merchant'
  message    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model Dispute {
  id                String    @id @default(cuid())
  orderId           String
  merchantId        String
  stripeDisputeId   String    @unique
  stripeChargeId    String?
  amount            Float
  currency          String    @default("USD")
  reason            String
  status            String    @default("warning_needs_response")
  evidenceDeadline  DateTime?
  evidenceSubmitted Boolean   @default(false)
  riskScore         Int       @default(0)
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model FraudFlag {
  id         String   @id @default(cuid())
  orderId    String?
  merchantId String
  type       String
  details    String
  severity   String   @default("medium")
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model Order {
  id              String   @id @default(cuid())
  orderId         String   @unique
  merchantId      String
  posId           String
  customerId      String?
  amount          Float
  currency        String   @default("USD")
  description     String?
  status          String   @default("pending")
  paymentIntentId String?
  expectedCardholder String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  merchant  Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  posDevice POSDevice @relation(fields: [posId], references: [id], onDelete: Cascade)
  customer  Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  payment   Payment?
}

model Payment {
  id             String   @id @default(cuid())
  orderId        String   @unique
  merchantId     String
  posId          String
  stripeChargeId String?
  cardBrand      String?
  cardLast4      String?
  cardholderName String?
  riskLevel      String?
  receiptUrl     String?
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model WebhookLog {
  id         String   @id @default(cuid())
  eventType  String
  payload    String
  receivedAt DateTime @default(now())
}

model DeviceLog {
  id         String   @id @default(cuid())
  posId      String
  merchantId String
  action     String
  details    String?
  createdAt  DateTime @default(now())

  posDevice POSDevice @relation(fields: [posId], references: [id], onDelete: Cascade)
}

model Transaction {
  id                    String   @id @default(cuid())
  merchantId            String
  posId                 String
  amount                Float
  currency              String   @default("USD")
  status                String   @default("PENDING")
  stripePaymentIntentId String?
  stripeChargeId        String?
  customerEmail         String?
  customerName          String?
  cardholderName        String?
  cardLast4             String?
  cardBrand             String?
  riskLevel             String?
  orderId               String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  merchant  Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  posDevice POSDevice @relation(fields: [posId], references: [id], onDelete: Cascade)
  refunds   Refund[]
}

model Refund {
  id                 String   @id @default(cuid())
  merchantId         String
  transactionId      String
  stripeRefundId     String   @unique
  stripeChargeId     String
  amount             Float
  currency           String   @default("USD")
  reason             String?
  status             String   @default("pending")
  adminNote          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  merchant    Merchant    @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}
